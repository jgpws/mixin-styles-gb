{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Playfair Display",
  "settings": {
    "typography": {
      "fontFamilies": [
        {
          "fontFace": [
            {
              "fontFamily": "\"Playfair Display\"",
              "fontStyle": "normal",
              "fontWeight": "400",
              "src": ["file:./build/assets/fonts/playfair-display/playfair-display-400-normal.woff2"]
            },
            {
              "fontFamily": "\"Playfair Display\"",
              "fontStyle": "normal",
              "fontWeight": "700",
              "src": ["file:./build/assets/fonts/playfair-display/playfair-display-700-normal.woff2"]
            },
            {
              "fontFamily": "\"Playfair Display\"",
              "fontStyle": "italic",
              "fontWeight": "400",
              "src": ["file:./build/assets/fonts/playfair-display/playfair-display-400-italic.woff2"]
            },
            {
              "fontFamily": "\"Playfair Display\"",
              "fontStyle": "italic",
              "fontWeight": "700",
              "src": ["file:./build/assets/fonts/playfair-display/playfair-display-700-italic.woff2"]
            }
          ],
          "fontFamily": "\"Playfair Display\", serif",
          "name": "Playfair Display",
          "slug": "body"
        },
        {
          "fontFace": [
            {
              "fontFamily": "\"Playfair Display\"",
              "fontStyle": "normal",
              "fontWeight": "700",
              "src": ["file:./build/assets/fonts/playfair-display/playfair-display-700-normal.woff2"]
            },
            {
              "fontFamily": "\"Playfair Display\"",
              "fontStyle": "italic",
              "fontWeight": "700",
              "src": ["file:./build/assets/fonts/playfair-display/playfair-display-700-italic.woff2"]
            }
          ],
          "fontFamily": "\"Playfair Display\", serif",
          "name": "Playfair Display",
          "slug": "heading"
        }
      ]
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontStyle": "normal",
          "fontWeight": "700",
          "fontFamily": "var(--wp--preset--font-family--heading)"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "textTransform": "uppercase"
        }
      },
      "core/site-tagline": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)",
          "fontSize": "1rem"
        }
      },
      "core/navigation": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)"
        }
      },
      "core/post-title": {
        "typography": {
          "textTransform": "capitalize"
        }
      }
    }
  }
}
