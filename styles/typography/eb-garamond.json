{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "EB Garamond",
  "styles": {
    "blocks": {
      "core/query-pagination": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--mxs-normal)"
        }
      },
      "core/comments-pagination": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--mxs-normal)"
        }
      },
      "core/post-navigation-link": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--mxs-normal)"
        }
      },
      "core/calendar": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--mxs-normal)"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--mxs-normal)"
        }
      }
    },
    "typography": {
      "fontFamily": "var:preset|font-family|heading",
      "fontSize": "1.25rem",
      "lineHeight": "1.4"
    }
  }
}
