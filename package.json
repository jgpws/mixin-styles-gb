{
  "name": "mixin-styles-gb",
  "version": "1.1.0",
  "description": "WordPress block theme",
  "main": "index.js",
  "scripts": {
    "start": "wp-scripts start --webpack-src-dir=resources --output-path=build/assets",
    "build": "wp-scripts build --webpack-src-dir=resources --output-path=build/assets",
    "postbuild": "npm run copy-dist",
    "autoprefix": "postcss build/*.css --use autoprefixer -d build/ --watch",
    "format": "wp-scripts format ./resources ./styles **/*.html",
    "clean-dist": "shx rm -rf dist",
    "copy-dist-folders": "shx mkdir -p dist && shx cp -r build resources styles parts patterns templates dist",
    "copy-dist-files": "shx mkdir -p dist && shx cp -r *.php style.css theme.json LICENSE readme.txt screenshot.png package.json webpack.config.js dist",
    "copy-dist": "npm run clean-dist && concurrently 'npm:copy-dist-folders' 'npm:copy-dist-files'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jgpws/mixin-styles-gb.git"
  },
  "author": "Jason Gonzalez",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jgpws/mixin-styles-gb/issues"
  },
  "homepage": "https://github.com/jgpws/mixin-styles-gb#readme",
  "devDependencies": {
    "@wordpress/scripts": "^31.1.0",
    "browser-sync": "^2.29.3",
    "browser-sync-webpack-plugin": "^2.4.0",
    "concurrently": "^8.0.1",
    "path": "^0.12.7",
    "renamer": "^4.0.0",
    "sass": "^1.62.1",
    "shx": "^0.4.0",
    "webpack-remove-empty-scripts": "^1.1.1"
  },
  "dependencies": {
    "@wordpress/data": "^10.37.0",
    "autoprefixer": "^10.4.22",
    "clean-css-cli": "^5.6.2",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1"
  }
}
